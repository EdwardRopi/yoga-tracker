+  display: flex; align-items: center; justify-content: center;
+  flex-shrink: 0;
+}
+.program-pose-svg {
+  width: 44px; height: 52px;
+  flex-shrink: 0;
+  color: var(--primary);
+}
+.program-pose-info {
+  flex: 1; min-width: 0;
+}
+.program-pose-name {
+  font-size: 13px; font-weight: 700; color: var(--text);
