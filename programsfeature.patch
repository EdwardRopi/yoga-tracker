+.builder-options-4 { grid-template-columns: repeat(4, 1fr); }
+.builder-option {
+  background: var(--surface);
+  backdrop-filter: var(--glass-blur);
+  border: 2px solid var(--border-subtle);
+  border-radius: 16px;
+  padding: 16px 10px;
+  display: flex; flex-direction: column;
+  align-items: center; gap: 4px;
+  cursor: pointer;
+  transition: all 0.25s cubic-bezier(0.34,1.56,0.64,1);
+  color: var(--text);
+}
+.builder-option:active { transform: scale(0.94); }
+.builder-option.builder-selected {
+  border-color: var(--primary);
+  background: var(--primary-soft);
+  box-shadow: 0 6px 20px var(--glow);
+  transform: scale(1.04);
+}
+.builder-option.builder-selected .builder-name { color: var(--primary); }
+.builder-emoji { font-size: 28px; }
+.builder-name { font-size: 13px; font-weight: 800; }
+.builder-sub  { font-size: 10px; color: var(--text-muted); font-weight: 600; }
+.builder-option-small .builder-name { font-size: 22px; font-weight: 900; }
+.builder-option-small .builder-sub  { font-size: 11px; }
+
+#builder-generate {
+  margin-top: 8px;
+}
+#builder-generate:disabled {
