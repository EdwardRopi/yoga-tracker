+.builder-content {
+  display: flex; flex-direction: column; gap: 22px;
+}
+.builder-step {
+  display: flex; flex-direction: column; gap: 10px;
+}
+.builder-step-label {
+  font-size: 11px; font-weight: 800;
+  color: var(--text-muted);
+  text-transform: uppercase; letter-spacing: 1.2px;
+}
