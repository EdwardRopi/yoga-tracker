--- /dev/null
+++ b/frontend/sw.js
@@ -0,0 +1,74 @@
+/* =====================================================
+   YOGA TRACKER — Service Worker
+   Strategies:
+   - Static assets: Cache-First (update in background)
+   - API GETs:      Network-First with cache fallback
+   - API mutations: Pass through (handled by offline queue in app.js)
+   ===================================================== */
+
+const CACHE = 'yoga-v1';
+const PRECACHE = ['/', '/app.js', '/styles.css', '/manifest.json', '/icon.svg'];
+
+self.addEventListener('install', e => {
+  e.waitUntil(
+    caches.open(CACHE)
+      .then(c => c.addAll(PRECACHE))
+      .then(() => self.skipWaiting())
+  );
+});
+
+self.addEventListener('activate', e => {
+  e.waitUntil(
+    caches.keys()
+      .then(keys => Promise.all(keys.filter(k => k !== CACHE).map(k => caches.delete(k))))
+      .then(() => self.clients.claim())
+  );
+});
+
+self.addEventListener('fetch', e => {
+  const { request } = e;
+  const url = new URL(request.url);
+
+  // Skip cross-origin requests (Telegram SDK, Chart.js CDN)
+  if (url.origin !== self.location.origin) return;
+
+  // API GET: network-first, fall back to cache
+  if (url.pathname.startsWith('/api/') && request.method === 'GET') {
+    e.respondWith(
+      fetch(request)
+        .then(res => {
+          if (res.ok) {
+            caches.open(CACHE).then(c => c.put(request, res.clone()));
+          }
+          return res;
+        })
+        .catch(() => caches.match(request))
+    );
+    return;
+  }
+
+  // API mutations (POST/DELETE): let through — app.js queues them offline
+  if (url.pathname.startsWith('/api/')) return;
+
+  // Static assets: cache-first, network fallback
+  e.respondWith(
+    caches.match(request).then(cached => {
+      const network = fetch(request).then(res => {
+        if (res.ok) caches.open(CACHE).then(c => c.put(request, res.clone()));
+        return res;
+      });
+      return cached || network;
+    })
+  );
+});
+
+// Background Sync: tell the app to flush its offline queue
+self.addEventListener('sync', e => {
+  if (e.tag === 'sync-sessions') {
+    e.waitUntil(
+      self.clients.matchAll().then(clients =>
+        clients.forEach(c => c.postMessage({ type: 'FLUSH_QUEUE' }))
+      )
+    );
+  }
+});
-- 
