+}
+
+.guided-next {
+  margin-top: 4px;
+  display: flex; flex-direction: column; align-items: center; gap: 4px;
+}
+.guided-next-label {
+  font-size: 10px; font-weight: 700;
+  color: var(--text-muted);
+  text-transform: uppercase; letter-spacing: 1px;
+}
+.guided-next-inner {
+  display: flex; align-items: center; gap: 10px;
