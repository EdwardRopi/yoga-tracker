+/* =====================================================
+   YOGA TRACKER — База из 100 поз
+   figure: { base, torso?, la, ra, ll, rl, px?, py?, head? }
+   Углы: 0=вверх, 90=вправо, 180=вниз, 270=влево
+   Поза смотрит вправо. la/ra — левая/правая рука; ll/rl — ноги.
+   ===================================================== */
+
+const POSES = [
+  // ============= СТОЯЧИЕ (25) =============
