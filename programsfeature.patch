+  font-weight: 600;
+}
+.finish-stat { display: flex; flex-direction: column; align-items: center; }
+.finish-stat-val {
+  font-size: 22px; font-weight: 900;
+  color: var(--primary);
+}
+.finish-actions {
+  display: flex; flex-direction: column; gap: 10px;
+  width: 100%; margin-top: 8px;
+}
+
+/* SVG позы в гиде */
+.pose-svg { display: block; }
+
