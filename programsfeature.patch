diff --git a/frontend/app.js b/frontend/app.js
index e7b9677..c8e62ca 100644
--- a/frontend/app.js
+++ b/frontend/app.js
@@ -1058,6 +1058,7 @@ let breathingState = {
 
 function loadPracticeTab() {
   loadPrograms();
+  if (typeof renderRecentPrograms === 'function') renderRecentPrograms();
 }
 
 function startBreathing(key) {
@@ -1301,8 +1302,425 @@ async function processOfflineQueue() {
   }
 }
 
-// Обновляем статистику после каждой записи
-const _origQuickLog = quickLog;
+// =====================================================
+// ГЕНЕРАТОР ПРОГРАММ
+// =====================================================
+
+const builderState = {
+  timeOfDay: null,
+  intensity: null,
+  duration:  null,
+};
+
+const programState = {
+  current:   null,   // последняя сгенерированная программа
+  guided:    {
+    poseIdx:    0,
+    remaining:  0,
+    interval:   null,
+    paused:     false,
+    startedAt:  0,
+  },
+};
+
+function autoTimeOfDay() {
+  const h = new Date().getHours();
+  if (h >= 5  && h < 11) return 'morning';
+  if (h >= 11 && h < 18) return 'day';
+  return 'evening';
+}
+
+function openProgramBuilder() {
+  // Сбрасываем выбор
+  builderState.timeOfDay = null;
+  builderState.intensity = null;
+  builderState.duration  = null;
+  document.querySelectorAll('.builder-option').forEach(b => b.classList.remove('builder-selected'));
+  document.getElementById('builder-generate').disabled = true;
+
+  // Автоматический выбор времени суток
+  const auto = autoTimeOfDay();
+  const autoBtn = document.querySelector(`.builder-option[data-key="timeOfDay"][data-value="${auto}"]`);
+  if (autoBtn) {
+    autoBtn.classList.add('builder-selected');
+    builderState.timeOfDay = auto;
+  }
+
+  showElement('program-builder');
+}
+
+function closeProgramBuilder() {
+  hideElement('program-builder');
+}
+
+function builderSelect(btn) {
+  const key   = btn.dataset.key;
+  const value = btn.dataset.value;
+
+  // Снимаем выбор у соседей того же ключа
+  document.querySelectorAll(`.builder-option[data-key="${key}"]`)
+    .forEach(b => b.classList.remove('builder-selected'));
+  btn.classList.add('builder-selected');
+
+  builderState[key] = key === 'duration' ? parseInt(value) : value;
+
+  // Активируем кнопку «Сгенерировать» если все 3 шага выбраны
+  const ready = builderState.timeOfDay && builderState.intensity && builderState.duration;
+  document.getElementById('builder-generate').disabled = !ready;
+}
+
+// === Алгоритм генерации программы ===
+const STRUCTURE = {
+  15: { total: 8,  warmup: 2, cooldown: 1 },
+  30: { total: 14, warmup: 3, cooldown: 2 },
+  45: { total: 18, warmup: 3, cooldown: 2 },
+  60: { total: 23, warmup: 4, cooldown: 2 },
+};
+
+function shuffle(arr) {
+  const a = [...arr];
+  for (let i = a.length - 1; i > 0; i--) {
+    const j = Math.floor(Math.random() * (i + 1));
+    [a[i], a[j]] = [a[j], a[i]];
+  }
+  return a;
+}
+
+function pickPoses(pool, phase, count, intensity, excludeIds) {
+  const exclude = new Set(excludeIds || []);
+  const phasePool = pool.filter(p => p.phase.includes(phase) && !exclude.has(p.id));
+  const sorted = [...phasePool].sort((a, b) => {
+    if (intensity === 'intensive')  return b.difficulty - a.difficulty;
+    if (intensity === 'relaxing')   return a.energy - b.energy;
+    if (intensity === 'meditative') return b.duration_hint - a.duration_hint;
+    return 0;
+  });
+  const topN = sorted.slice(0, Math.max(count * 2, 6));
+  const picked = shuffle(topN).slice(0, count);
+
+  // Если не хватает — добираем из всего фазного пула (без exclude)
+  for (const p of phasePool) {
+    if (picked.length >= count) break;
+    if (!picked.some(x => x.id === p.id)) picked.push(p);
+  }
+  return picked;
+}
+
+// Сортировка основных поз: стоячие → пол → перевёрнутые → баланс
+const CATEGORY_ORDER = { standing:1, balance:2, prone:3, seated:4, supine:5, inverted:6, breathing:0 };
+
+function orderMainPoses(poses) {
+  return [...poses].sort((a, b) => {
+    const ca = CATEGORY_ORDER[a.category] ?? 9;
+    const cb = CATEGORY_ORDER[b.category] ?? 9;
+    if (ca !== cb) return ca - cb;
+    return a.difficulty - b.difficulty;
+  });
+}
+
+function generateProgram({ timeOfDay, intensity, duration }) {
+  const suitable = POSES.filter(p =>
+    p.time_of_day.includes(timeOfDay) &&
+    p.intensity.includes(intensity)
+  );
+  if (suitable.length === 0) return null;
+
+  const S = STRUCTURE[duration];
+  const mainCount = S.total - S.warmup - S.cooldown;
+
+  const warmup = pickPoses(suitable, 'warmup', S.warmup, intensity, []);
+  const usedAfterWarmup = warmup.map(p => p.id);
+
+  const main = orderMainPoses(
+    pickPoses(suitable, 'main', mainCount, intensity, usedAfterWarmup)
+  );
+  const usedAfterMain = [...usedAfterWarmup, ...main.map(p => p.id)];
+
+  const cooldown = pickPoses(suitable, 'cooldown', S.cooldown, intensity, usedAfterMain);
+
+  // Шавасана в конец, если её нет
+  const savasana = POSES.find(p => p.id === 'savasana');
+  if (savasana && intensity !== 'intensive' && !cooldown.some(p => p.id === 'savasana')) {
+    cooldown[cooldown.length - 1] = savasana;
+  }
+
+  const sequence = [...warmup, ...main, ...cooldown];
+
+  // Распределение времени
+  const total = duration * 60;
+  const warmupSec   = 45;
+  const cooldownSec = duration >= 45 ? 120 : 90;
+  const mainTotal   = total - (warmupSec * S.warmup) - (cooldownSec * S.cooldown);
+  const mainPerPose = Math.max(45, Math.floor(mainTotal / mainCount));
+
+  const timed = sequence.map((pose, i) => {
+    let sec, phase;
+    if (i < S.warmup) {
+      sec = warmupSec; phase = 'warmup';
+    } else if (i >= sequence.length - S.cooldown) {
+      sec = cooldownSec; phase = 'cooldown';
+    } else {
+      sec = mainPerPose; phase = 'main';
+    }
+    return { ...pose, assigned_seconds: sec, phase_in_program: phase };
+  });
+
+  return {
+    id:        Date.now(),
+    timeOfDay, intensity, duration,
+    poses:     timed,
+    createdAt: new Date().toISOString(),
+  };
+}
+
+const TIME_LABELS      = { morning:'Утренняя',   day:'Дневная',     evening:'Вечерняя' };
+const INTENSITY_LABELS = { intensive:'Интенсивная', relaxing:'Расслабляющая', meditative:'Медитативная' };
+const TIME_EMOJIS      = { morning:'🌅', day:'☀️', evening:'🌙' };
+const INTENSITY_EMOJIS = { intensive:'💪', relaxing:'🌿', meditative:'🧘' };
+const PHASE_LABELS     = { warmup:'РАЗОГРЕВ', main:'ОСНОВНАЯ', cooldown:'ЗАВЕРШЕНИЕ' };
+
+function generateAndShowProgram() {
+  if (!builderState.timeOfDay || !builderState.intensity || !builderState.duration) return;
+  const prog = generateProgram(builderState);
+  if (!prog) { toast('Не удалось подобрать позы'); return; }
+
+  programState.current = prog;
+  saveRecentProgram(prog);
+  closeProgramBuilder();
+  showProgramView(prog);
+}
+
+function showProgramView(prog) {
+  document.getElementById('program-view-title').textContent =
+    `${TIME_EMOJIS[prog.timeOfDay]} ${TIME_LABELS[prog.timeOfDay]}`;
+
+  document.getElementById('program-meta').innerHTML = `
+    <span class="program-meta-chip">${INTENSITY_EMOJIS[prog.intensity]} ${INTENSITY_LABELS[prog.intensity]}</span>
+    <span class="program-meta-chip">⏱ ${prog.duration} мин</span>
+    <span class="program-meta-chip">🧘 ${prog.poses.length} поз</span>
+  `;
+
+  const list = document.getElementById('program-poses-list');
+  list.innerHTML = prog.poses.map((p, i) => {
+    const mins = Math.floor(p.assigned_seconds / 60);
+    const secs = p.assigned_seconds % 60;
+    const time = mins > 0 ? `${mins}м ${secs}с` : `${secs}с`;
+    return `
+      <div class="program-pose-row">
+        <div class="program-pose-num">${i + 1}</div>
+        <div class="program-pose-svg">${renderPoseSVG(p, { size: 44 })}</div>
+        <div class="program-pose-info">
+          <div class="program-pose-name">${p.name_ru}</div>
+          <div class="program-pose-time">${time}</div>
+        </div>
+        <div class="program-pose-phase phase-${p.phase_in_program}">${PHASE_LABELS[p.phase_in_program]}</div>
+      </div>
+    `;
+  }).join('');
+
+  showElement('program-view');
+}
+
+function closeProgramView() {
+  hideElement('program-view');
+}
+
+function regenerateProgram() {
+  if (!programState.current) return;
+  const prog = generateProgram({
+    timeOfDay: programState.current.timeOfDay,
+    intensity: programState.current.intensity,
+    duration:  programState.current.duration,
+  });
+  if (!prog) return;
+  programState.current = prog;
+  saveRecentProgram(prog);
+  showProgramView(prog);
+  toast('Программа обновлена ↺');
+}
+
+// === Сохранение последних программ ===
+function saveRecentProgram(prog) {
+  try {
+    const stored = JSON.parse(localStorage.getItem('yt_programs') || '[]');
+    stored.unshift({
+      id: prog.id, timeOfDay: prog.timeOfDay, intensity: prog.intensity,
+      duration: prog.duration, poses: prog.poses, createdAt: prog.createdAt,
+      completed: false,
+    });
+    localStorage.setItem('yt_programs', JSON.stringify(stored.slice(0, 10)));
+  } catch (e) {}
+  renderRecentPrograms();
+}
+
+function renderRecentPrograms() {
+  const container = document.getElementById('recent-programs');
+  if (!container) return;
+  const stored = JSON.parse(localStorage.getItem('yt_programs') || '[]');
+  if (!stored.length) { container.classList.add('hidden'); return; }
+  container.classList.remove('hidden');
+  container.innerHTML = stored.slice(0, 3).map(p => `
+    <div class="recent-program-chip" onclick="reopenRecentProgram(${p.id})">
+      <span>${TIME_EMOJIS[p.timeOfDay]} ${INTENSITY_EMOJIS[p.intensity]}</span>
+      <span class="recent-program-chip-meta">${INTENSITY_LABELS[p.intensity]} · ${p.duration} мин</span>
+      <span>${p.completed ? '✓' : '▶'}</span>
+    </div>
+  `).join('');
+}
+
+function reopenRecentProgram(id) {
+  const stored = JSON.parse(localStorage.getItem('yt_programs') || '[]');
+  const prog = stored.find(p => p.id === id);
+  if (!prog) return;
+  programState.current = prog;
+  showProgramView(prog);
+}
+
+// =====================================================
+// РЕЖИМ ГИДА
+// =====================================================
+function startGuidedMode() {
+  if (!programState.current) return;
+  programState.guided.poseIdx   = 0;
+  programState.guided.paused    = false;
+  programState.guided.startedAt = Date.now();
+  hideElement('program-view');
+  showElement('guided-mode');
+  renderGuidedPose();
+  startGuidedTimer();
+}
+
+function renderGuidedPose() {
+  const prog = programState.current;
+  const idx  = programState.guided.poseIdx;
+  const pose = prog.poses[idx];
+
+  document.getElementById('guided-position').textContent = `${idx + 1} / ${prog.poses.length}`;
+  document.getElementById('guided-progress-fill').style.width =
+    `${((idx) / prog.poses.length) * 100}%`;
+
+  document.getElementById('guided-pose-svg').innerHTML = renderPoseSVG(pose, { size: 180 });
+  document.getElementById('guided-pose-name').textContent    = pose.name_ru;
+  document.getElementById('guided-pose-name-en').textContent = pose.name_en;
+  document.getElementById('guided-breath').textContent       = pose.breath || '';
+
+  // Следующая поза
+  const next = prog.poses[idx + 1];
+  const nextBox = document.getElementById('guided-next');
+  if (next) {
+    nextBox.classList.remove('hidden');
+    document.getElementById('guided-next-svg').innerHTML  = renderPoseSVG(next, { size: 32 });
+    document.getElementById('guided-next-name').textContent = next.name_ru;
+  } else {
+    nextBox.classList.add('hidden');
+  }
+
+  programState.guided.remaining = pose.assigned_seconds;
+  updateGuidedTimerDisplay();
+}
+
+function startGuidedTimer() {
+  if (programState.guided.interval) clearInterval(programState.guided.interval);
+  programState.guided.interval = setInterval(() => {
+    if (programState.guided.paused) return;
+    programState.guided.remaining--;
+    updateGuidedTimerDisplay();
+    if (programState.guided.remaining <= 0) {
+      advanceGuidedPose();
+    }
+  }, 1000);
+}
+
+function updateGuidedTimerDisplay() {
+  const sec = Math.max(0, programState.guided.remaining);
+  const mins = Math.floor(sec / 60);
+  const secs = sec % 60;
+  document.getElementById('guided-timer-text').textContent =
+    `${mins}:${String(secs).padStart(2,'0')}`;
+
+  const total   = programState.current.poses[programState.guided.poseIdx].assigned_seconds;
+  const ratio   = sec / total;
+  const dashLen = 289;
+  document.getElementById('guided-ring-fg').style.strokeDashoffset = dashLen * (1 - ratio);
+}
+
+function advanceGuidedPose() {
+  const prog = programState.current;
+  programState.guided.poseIdx++;
+  if (programState.guided.poseIdx >= prog.poses.length) {
+    finishGuidedMode();
+    return;
+  }
+  renderGuidedPose();
+}
+
+function guidedSkip() {
+  advanceGuidedPose();
+}
+
+function guidedPauseToggle() {
+  programState.guided.paused = !programState.guided.paused;
+  document.getElementById('guided-pause-btn').textContent =
+    programState.guided.paused ? '▶' : '⏸';
+}
+
+function exitGuidedMode() {
+  if (!confirm('Завершить тренировку?')) return;
+  clearInterval(programState.guided.interval);
+  programState.guided.interval = null;
+  hideElement('guided-mode');
+}
+
+function finishGuidedMode() {
+  clearInterval(programState.guided.interval);
+  programState.guided.interval = null;
+  hideElement('guided-mode');
+
+  const prog = programState.current;
+  const elapsed = Math.floor((Date.now() - programState.guided.startedAt) / 1000);
+  const mins = Math.floor(elapsed / 60);
+
+  // Помечаем завершённой в истории
+  try {
+    const stored = JSON.parse(localStorage.getItem('yt_programs') || '[]');
+    const p = stored.find(x => x.id === prog.id);
+    if (p) { p.completed = true; p.completedAt = new Date().toISOString(); }
+    localStorage.setItem('yt_programs', JSON.stringify(stored));
+  } catch (e) {}
+
+  // Логируем как сессию йоги (получаем XP, обновляем стрик)
+  const today = getTodayStr();
+  const diff  = prog.intensity === 'intensive' ? 3 :
+                prog.intensity === 'relaxing'  ? 2 : 1;
+  const type  = prog.intensity === 'intensive'  ? 'vinyasa' :
+                prog.intensity === 'meditative' ? 'meditation' : 'yin';
+  apiFetch('/api/yoga/sessions', {
+    method: 'POST',
+    body: JSON.stringify({ date: today, difficulty: diff, type, duration: elapsed })
+  }).then(() => {
+    awardXP(diff, elapsed);
+    loadStreak();
+    loadWeekStats();
+  }).catch(() => {});
+
+  // Экран завершения
+  document.getElementById('finish-stats').innerHTML = `
+    <div class="finish-stat"><span class="finish-stat-val">${mins}</span><span>минут</span></div>
+    <div class="finish-stat"><span class="finish-stat-val">${prog.poses.length}</span><span>поз</span></div>
+    <div class="finish-stat"><span class="finish-stat-val">+${prog.poses.length * 5}</span><span>XP</span></div>
+  `;
+  showElement('program-finish');
+  renderRecentPrograms();
+}
+
+function restartProgram() {
+  hideElement('program-finish');
+  if (programState.current) startGuidedMode();
+}
+
+function exitFinishScreen() {
+  hideElement('program-finish');
+}
 
