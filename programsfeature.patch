+}
+.phase-warmup   { background: rgba(108,184,178,0.18); color: #5cb8b2; }
+.phase-main     { background: rgba(240,144,64,0.18);  color: #f09040; }
+.phase-cooldown { background: rgba(192,132,252,0.18); color: var(--primary); }
+
+/* =====================================================
+   РЕЖИМ ГИДА
+   ===================================================== */
+.guided-screen {
+  background: linear-gradient(180deg, var(--bg) 0%, var(--primary-soft) 100%);
+}
+.guided-header {
+  display: flex; align-items: center; gap: 12px;
+  padding: 14px 16px;
+}
+.guided-close {
+  width: 36px; height: 36px;
+  background: var(--surface);
+  border: 1px solid var(--border-subtle);
+  border-radius: 50%; cursor: pointer;
+  font-size: 16px; color: var(--text);
+  display: flex; align-items: center; justify-content: center;
+}
+.guided-close:active { transform: scale(0.9); }
+.guided-progress { flex: 1; display: flex; flex-direction: column; gap: 5px; }
