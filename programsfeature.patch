+// ОФЛАЙН-СИНХРОНИЗАЦИЯ
+// =====================================================
+async function processOfflineQueue() {
+  const queue = JSON.parse(localStorage.getItem('yt_offline_queue') || '[]');
+  if (!queue.length || !state.token) return;
+
+  let synced = 0;
+  for (const session of queue) {
+    try {
+      const res = await apiFetch('/api/yoga/sessions', {
+        method: 'POST',
+        body: JSON.stringify(session)
+      });
+      if (res.ok) {
+        synced++;
+        awardXP(session.difficulty, session.duration || 0);
+      } else {
+        break;
+      }
+    } catch (e) {
+      break; // Всё ещё нет сети — попробуем позже
+    }
+  }
+
+  if (synced > 0) {
+    localStorage.removeItem('yt_offline_queue');
+    await loadStreak();
+    loadWeekStats();
+    if (state.currentTab === 'calendar') loadCalendar();
+    const word = synced === 1 ? 'практика' : synced < 5 ? 'практики' : 'практик';
+    toast(`Синхронизировано: ${synced} ${word} ✓`);
+  }
+}
