index 0000000..4cbcde2
--- /dev/null
+++ b/frontend/pose-svg.js
@@ -0,0 +1,93 @@
+/* =====================================================
+   YOGA TRACKER — Stick Figure SVG Engine
+   Рендер позы из параметров figure: {base, torso, arms, legs, ...}
+   Углы в мире: 0 = вверх, 90 = вправо, 180 = вниз, 270 = влево
+   ===================================================== */
+
+function polarFrom(origin, angleDeg, length) {
+  const rad = (angleDeg * Math.PI) / 180;
+  return {
+    x: origin.x + length * Math.sin(rad),
+    y: origin.y - length * Math.cos(rad),
+  };
+}
+
+const POSE_BASES = {
+  stand:     { px: 50, py: 60,  torso: 0   },
+  sit:       { px: 50, py: 78,  torso: 0   },
+  kneel:     { px: 50, py: 70,  torso: 0   },
+  forward:   { px: 38, py: 60,  torso: 95  },
+  invert:    { px: 50, py: 40,  torso: 180 },
+  backbend:  { px: 50, py: 65,  torso: -25 },
+  prone:     { px: 30, py: 78,  torso: 90  },
+  supine:    { px: 30, py: 82,  torso: 90  },
+  sideplank: { px: 25, py: 75,  torso: 65  },
+  hands:     { px: 50, py: 75,  torso: 180 },
+  lunge:     { px: 50, py: 65,  torso: 0   },
+  child:     { px: 35, py: 78,  torso: 110 },
+};
+
+function renderPoseSVG(pose, opts = {}) {
+  const size  = opts.size  || 100;
+  const color = opts.color || 'currentColor';
+  const W = size, H = size * 1.2;
+  const k = size / 100;
+
+  const HEAD_R     = 5    * k;
+  const TORSO_LEN  = 22   * k;
+  const UPPER_ARM  = 13   * k;
+  const FOREARM    = 12   * k;
+  const THIGH      = 17   * k;
+  const SHIN       = 16   * k;
+  const FOOT       = 5    * k;
+
+  const fig = pose.figure || pose;
+  const base = POSE_BASES[fig.base] || POSE_BASES.stand;
+  const px = (fig.px !== undefined ? fig.px : base.px) + (fig.dx || 0);
+  const py = (fig.py !== undefined ? fig.py : base.py) + (fig.dy || 0);
+  const pelvis = { x: px * k, y: py * k };
+  const torsoAngle = fig.torso !== undefined ? fig.torso : base.torso;
+
+  const neck = polarFrom(pelvis, torsoAngle, TORSO_LEN);
+  const headDir = torsoAngle + (fig.head || 0);
+  const head = polarFrom(neck, headDir, HEAD_R * 1.6);
+
+  // Руки: [плечо_угол, предплечье_угол] — оба в мировых координатах
+  const la = fig.la || [torsoAngle + 180, torsoAngle + 180];
+  const ra = fig.ra || [torsoAngle + 180, torsoAngle + 180];
+  const leftElbow  = polarFrom(neck, la[0], UPPER_ARM);
+  const leftHand   = polarFrom(leftElbow, la[1], FOREARM);
+  const rightElbow = polarFrom(neck, ra[0], UPPER_ARM);
+  const rightHand  = polarFrom(rightElbow, ra[1], FOREARM);
+
+  // Ноги: [бедро_угол, голень_угол]
+  const ll = fig.ll || [180, 180];
+  const rl = fig.rl || [180, 180];
+  const leftKnee  = polarFrom(pelvis, ll[0], THIGH);
+  const leftFoot  = polarFrom(leftKnee, ll[1], SHIN);
+  const rightKnee = polarFrom(pelvis, rl[0], THIGH);
+  const rightFoot = polarFrom(rightKnee, rl[1], SHIN);
+
+  const SW = (2.8 * k).toFixed(2);
+  const SWL = (2.4 * k).toFixed(2);
+  const baseAttr = `stroke="${color}" stroke-linecap="round" fill="none"`;
+  const front = `${baseAttr} stroke-width="${SW}"`;
+  const back  = `${baseAttr} stroke-width="${SWL}" stroke-opacity="0.55"`;
+
+  function L(a, b, attr) {
+    return `<line x1="${a.x.toFixed(1)}" y1="${a.y.toFixed(1)}" x2="${b.x.toFixed(1)}" y2="${b.y.toFixed(1)}" ${attr}/>`;
+  }
+
+  return `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" class="pose-svg">
+    ${L(pelvis, neck, front)}
+    <circle cx="${head.x.toFixed(1)}" cy="${head.y.toFixed(1)}" r="${HEAD_R}" stroke="${color}" stroke-width="${SWL}" fill="none"/>
+    ${L(neck, leftElbow, back)}
+    ${L(leftElbow, leftHand, back)}
+    ${L(neck, rightElbow, front)}
+    ${L(rightElbow, rightHand, front)}
+    ${L(pelvis, leftKnee, back)}
+    ${L(leftKnee, leftFoot, back)}
+    ${L(pelvis, rightKnee, front)}
+    ${L(rightKnee, rightFoot, front)}
+  </svg>`;
+}
